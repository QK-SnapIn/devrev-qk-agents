      "oasis": {
        "datasets": [
          "devrev.dim_ticket",
          "devrev.dim_group",
          "devrev.dim_survey_response",
          "devrev.dim_devu"
        ],
        "sql_query": "SELECT * FROM (WITH csat_responses AS (SELECT sr.*, json_extract(sr.response, '$.rating') AS rating, ROW_NUMBER() OVER (PARTITION BY sr.display_id ORDER BY sr.modified_date DESC) AS rn FROM devrev.dim_survey_response sr WHERE json_extract(sr.response, '$.rating') IS NOT NULL), merged AS (SELECT t.id AS object, t.\"group\" AS group_id, t.*, t.stage_json, g.name AS group_name, cr.rating, cr.created_date AS csat_sent_date, cr.modified_date AS csat_response_date, u.owner_id, du.id AS user_id, du.reports_to_id, json_extract_string(t.custom_fields, '$.tnt__business_type') AS business_type, json_extract_string(t.custom_fields, '$.tnt__product_type') AS product_types, json_extract_string(t.custom_fields, '$.tnt__association_type') AS association_type, json_extract_string(t.custom_fields, '$.tnt__service_request_type') AS service_type FROM devrev.dim_ticket t LEFT JOIN csat_responses cr ON cr.object = t.id AND cr.rn = 1 LEFT JOIN devrev.dim_group g ON t.group = g.id CROSS JOIN UNNEST(t.owned_by_ids) AS u(owner_id) LEFT JOIN devrev.dim_devu du ON du.id = u.owner_id) SELECT * FROM merged WHERE rating IS NOT NULL AND group_id NOT IN ('don:identity:dvrv-in-1:devo/2CUcav2K66:group/14')) AS csat"
      },
      "reference_name": "csat",
      "type": "oasis"
    }
